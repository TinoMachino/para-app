{
  "lexicon": 1,
  "id": "com.para.discourse.getTopics",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get emergent topic clusters for a community.",
      "parameters": {
        "type": "params",
        "properties": {
          "community": { "type": "string" },
          "timeframe": { "type": "string", "enum": ["1h", "24h", "7d", "30d"] }
        },
        "required": ["timeframe"]
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["topics"],
          "properties": {
            "topics": {
              "type": "array",
              "items": { "type": "ref", "ref": "#topic" }
            }
          }
        }
      }
    },
    "topic": {
      "type": "object",
      "required": ["clusterLabel", "postCount", "authorCount"],
      "properties": {
        "clusterLabel": { "type": "string" },
        "keywords": { "type": "string" },
        "postCount": { "type": "integer" },
        "authorCount": { "type": "integer" },
        "avgSentiment": { "type": "integer", "description": "Scaled 0-100" }
      }
    }
  }
}
