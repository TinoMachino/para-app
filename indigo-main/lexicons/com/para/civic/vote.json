{
  "lexicon": 1,
  "id": "com.para.civic.vote",
  "defs": {
    "main": {
      "type": "record",
      "description": "The cast vote on a deliberation.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["cabildeo", "selectedOption", "isDirect", "createdAt"],
        "properties": {
          "cabildeo": { "type": "string", "format": "at-uri" },
          "selectedOption": { "type": "integer", "minimum": 0 },
          "isDirect": { "type": "boolean" },
          "delegatedFrom": {
            "type": "array",
            "items": { "type": "string", "format": "did" },
            "maxLength": 10000
          },
          "createdAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
