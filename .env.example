# Optional environment for local development.
# Most web-only workflows can run without this file.

EXPO_PUBLIC_ENV=development
EXPO_PUBLIC_LOG_LEVEL=info
EXPO_PUBLIC_USE_MOCK_DATA=false

# Optional service overrides for local development.
EXPO_PUBLIC_USE_LOCAL_DEV_SERVICE=0
EXPO_PUBLIC_LOCAL_DEV_IP=
EXPO_PUBLIC_LOCAL_DEV_SERVICE=
EXPO_PUBLIC_DEFAULT_SERVICE=

# Optional public runtime config.
EXPO_PUBLIC_API_URL=https://api.para.app
EXPO_PUBLIC_RELEASE_VERSION=
EXPO_PUBLIC_BUNDLE_IDENTIFIER=dev

# Optional integrations. Leave blank unless you explicitly need them.
GOOGLE_MAPS_API_KEY=
SENTRY_AUTH_TOKEN=
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_BITDRIFT_API_KEY=
EXPO_PUBLIC_GCP_PROJECT_ID=
